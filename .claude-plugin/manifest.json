{
  "name": "boundline",
  "displayName": "Boundline Assistant Support for Claude Code",
  "version": "0.49.0",
  "description": "Local delivery orchestrator for bounded engineering work",
  "author": {
    "name": "Apply The",
    "url": "https://github.com/apply-the"
  },
  "homepage": "https://github.com/apply-the/boundline",
  "repository": "https://github.com/apply-the/boundline",
  "license": "MIT",
  "keywords": [
    "boundline",
    "delivery",
    "bounded-engineering",
    "session-native"
  ],
  "capabilities": [
    {"id": "/boundline:start", "label": "start"},
    {"id": "/boundline:capture", "label": "capture"},
    {"id": "/boundline:plan", "label": "plan"},
    {"id": "/boundline:run", "label": "run"},
    {"id": "/boundline:status", "label": "status"},
    {"id": "/boundline:inspect", "label": "inspect"},
    {"id": "/boundline:recover", "label": "recover"},
    {"id": "/boundline:govern", "label": "govern", "conditional": true}
  ],
  "positioning": [
    "Local delivery orchestrator for bounded engineering work",
    "Plan, act, verify, trace",
    "Session-native runtime for AI-assisted software delivery"
  ],
  "paths": {
    "commands": "assistant/commands/session-workflow.json",
    "claudeCommands": "assistant/claude/commands",
    "starterPrompts": "assistant/prompts/starter-prompts.md",
    "icon": "assistant/assets/boundline-plugin-icon.svg",
    "logo": "assistant/assets/boundline-plugin-logo.svg"
  },
  "commands": ".claude-plugin/commands.json"
}
