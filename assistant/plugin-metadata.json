{
  "name": "boundline",
  "displayName": "Boundline Assistant Support",
  "version": "0.73.0",
  "description": "CLI-authoritative assistant support for bounded engineering work",
  "author": {
    "name": "Apply The",
    "url": "https://github.com/apply-the"
  },
  "homepage": "https://github.com/apply-the/boundline",
  "repository": "https://github.com/apply-the/boundline",
  "license": "MIT",
  "keywords": [
    "boundline",
    "delivery",
    "bounded-engineering",
    "plan-act-verify-trace",
    "session-native",
    "ai-assisted-software-delivery"
  ],
  "positioning": [
    "CLI-authoritative assistant support for bounded engineering work",
    "Plan, act, verify, trace",
    "Turns bounded engineering goals into verified workspace changes",
    "Session-native runtime for AI-assisted software delivery"
  ],
  "defaultPalette": [
    "/boundline:goal",
    "/boundline:plan",
    "/boundline:run",
    "/boundline:status",
    "/boundline:continue",
    "/boundline:inspect",
    "/boundline:why",
    "/boundline:risk",
    "/boundline:evidence",
    "/boundline:next-best",
    "/boundline:assumptions",
    "/boundline:hidden-impact",
    "/boundline:challenge"
  ],
  "contextualCommands": [
    "/boundline:explain-plan",
    "/boundline:doctor-context"
  ],
  "capabilities": [
    {
      "id": "/boundline:goal",
      "label": "goal"
    },
    {
      "id": "/boundline:plan",
      "label": "plan"
    },
    {
      "id": "/boundline:run",
      "label": "run"
    },
    {
      "id": "/boundline:status",
      "label": "status"
    },
    {
      "id": "/boundline:continue",
      "label": "continue"
    },
    {
      "id": "/boundline:inspect",
      "label": "inspect"
    },
    {
      "id": "/boundline:why",
      "label": "why"
    },
    {
      "id": "/boundline:risk",
      "label": "risk"
    },
    {
      "id": "/boundline:evidence",
      "label": "evidence"
    },
    {
      "id": "/boundline:next-best",
      "label": "next-best"
    },
    {
      "id": "/boundline:assumptions",
      "label": "assumptions"
    },
    {
      "id": "/boundline:hidden-impact",
      "label": "hidden-impact"
    },
    {
      "id": "/boundline:challenge",
      "label": "challenge"
    },
    {
      "id": "/boundline:explain-plan",
      "label": "explain-plan",
      "visibility": "contextual"
    },
    {
      "id": "/boundline:doctor-context",
      "label": "doctor-context",
      "visibility": "contextual"
    },
    {
      "id": "/boundline:recover",
      "label": "recover"
    },
    {
      "id": "/boundline:govern",
      "label": "govern",
      "conditional": true
    }
  ],
  "requiredPaths": [
    ".claude-plugin/manifest.json",
    ".claude-plugin/commands.json",
    ".antigravity-plugin/manifest.json",
    ".antigravity-plugin/commands.json",
    ".codex-plugin/plugin.json",
    ".cursor-plugin/manifest.json",
    ".cursor-plugin/commands.json",
    ".copilot-prompts/README.md",
    ".copilot-prompts/pack.json",
    "assistant/commands/session-workflow.json",
    "assistant/prompts/starter-prompts.md",
    "assistant/prompts/copilot-command-pack.md",
    "assistant/assets/boundline-plugin-icon.svg",
    "assistant/assets/boundline-plugin-logo.svg"
  ],
  "supportedHosts": [
    {
      "id": "claude-code",
      "displayName": "Claude Code",
      "packagePath": ".claude-plugin",
      "manifestPath": ".claude-plugin/manifest.json"
    },
    {
      "id": "codex",
      "displayName": "Codex",
      "packagePath": ".codex-plugin",
      "manifestPath": ".codex-plugin/plugin.json"
    },
    {
      "id": "cursor",
      "displayName": "Cursor",
      "packagePath": ".cursor-plugin",
      "manifestPath": ".cursor-plugin/manifest.json"
    },
    {
      "id": "copilot-prompts",
      "displayName": "Copilot prompt pack",
      "packagePath": ".copilot-prompts",
      "manifestPath": ".copilot-prompts/pack.json"
    },
    {
      "id": "antigravity",
      "displayName": "Antigravity",
      "packagePath": ".antigravity-plugin",
      "manifestPath": ".antigravity-plugin/manifest.json"
    }
  ],
  "hostSupportScope": "supportedHosts lists packaged repo-local assets; supportModes declares whether each host is repo-local-full, copy-ready-assets, or manual-fallback",
  "supportModes": {
    "claude": "repo-local-full",
    "codex": "repo-local-full",
    "cursor": "copy-ready-assets",
    "copilot": "repo-local-full",
    "antigravity": "repo-local-full"
  },
  "supportModeNotes": {
    "claude": "Repository-managed command assets expose the shared Boundline session workflow and delight follow-through surfaces directly.",
    "codex": "Repository-managed command assets expose the shared Boundline session workflow and delight follow-through surfaces directly.",
    "cursor": "Cursor remains in copy-ready-assets support mode: assets are copy-ready rather than self-registering, installation details remain environment-specific, and the CLI stays authoritative.",
    "copilot": "Repository-managed prompt assets expose the Boundline delight surface directly even though global bootstrap installation remains a manual fallback.",
    "antigravity": "Repository-managed Antigravity repo-local command assets bootstrap through `boundline init --assistant antigravity` and refresh through `boundline update --workspace <workspace> --target assistant --apply`, while global bootstrap remains a manual fallback."
  },
  "copilot": {
    "manifestSupported": false,
    "commandPromptPack": "assistant/prompts/copilot-command-pack.md"
  },
  "prohibitedPositioning": [
    "agent framework",
    "debate cli",
    "prompt library",
    "governance runtime",
    "replacement for canon",
    "raw cli"
  ]
}
